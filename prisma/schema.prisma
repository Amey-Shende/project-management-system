// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  CEO
  PM
  TL
  TM
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(70)
  email       String  @unique
  password    String?
  role        Role
  skills      Json?   @default("[]")
  department  String? @db.VarChar(50)
  designation String? @db.VarChar(50)
  phone       String? @db.VarChar(20)
  avatar      String? @db.VarChar(255)
  isActive    Boolean @default(true)

  //🔹 Self-relation for hierarchy
  managerId    Int?
  manager      User?  @relation("UserHierarchy", fields: [managerId], references: [id])
  subordinates User[] @relation("UserHierarchy")

  //🔹 Relations - All project assignments via ProjectMember
  memberProjects  ProjectMember[] @relation("ProjectUser")
  managedProjects ProjectMember[] @relation("ProjectManager")   

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Project {
  id          Int             @id @default(autoincrement())
  name        String          @db.VarChar(100)
  description String?         @db.Text
  status      ProjectStatus   @default(ACTIVE)
  techstack   Json?           @default("[]")
  priority    ProjectPriority @default(MEDIUM)
  startDate   DateTime?
  endDate     DateTime?
  progress    Int             @default(0) @db.TinyInt

  //🔹 All team members (PM, TL, TM) via ProjectMember
  members ProjectMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("projects")
}

model ProjectMember {
  id         Int      @id @default(autoincrement())
  userId     Int
  projectId  Int
  managerId  Int?   
  role       Role
  notes      String?  @db.Text
  user       User     @relation("ProjectUser", fields: [userId], references: [id])
  manager    User?    @relation("ProjectManager", fields: [managerId], references: [id])
  project    Project  @relation(fields: [projectId], references: [id])
  assignedAt DateTime @default(now())

  @@unique([userId, projectId])
}